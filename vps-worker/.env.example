# ============================================
# Flowtix VPS Worker - Environment Configuration
# ============================================
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env to git.

# Base URL of your Flowtix site (no trailing slash)
API_BASE_URL=https://flowtix-social-connect.lovable.app

# Worker shared secret (must match BOT_WORKER_SECRET in Lovable Cloud)
BOT_WORKER_SECRET=replace-with-the-same-secret-from-lovable-cloud

# How often (ms) to poll for new jobs when idle
POLL_INTERVAL_MS=5000

# Max number of comment pages to scroll/extract per job
MAX_COMMENT_SCROLLS=40

# Run Chromium headless (true on a VPS without display)
HEADLESS=true
