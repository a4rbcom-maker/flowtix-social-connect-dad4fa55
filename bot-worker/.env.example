# Flowtix VPS Worker config
API_BASE_URL=https://flowtix-social-connect.lovable.app
BOT_WORKER_SECRET=PASTE_YOUR_BOT_WORKER_SECRET_HERE
# Polling interval (seconds) when there ARE jobs
POLL_INTERVAL_SEC=15
# Max polling interval (seconds) when no jobs (exponential backoff caps here)
POLL_MAX_INTERVAL_SEC=60
# Headless browser? (true on a server, false to debug locally)
HEADLESS=true
